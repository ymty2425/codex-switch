{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Switch",
  "version": "0.1.0",
  "identifier": "com.codex.switch",
  "build": {
    "beforeDevCommand": "npm --prefix .. run dev",
    "beforeBuildCommand": "npm --prefix .. run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Switch",
        "width": 1120,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
